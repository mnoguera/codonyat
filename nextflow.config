params {
    input              = null
    reference          = null
    amplicons          = null
    protein            = 'RT'
    outdir             = './results'
    skip_dedup         = true
    skip_fastqc        = false
    bowtie2_args       = '--very-sensitive-local --no-unal'
    fastp_args         = '--qualified_quality_phred 20 --length_required 50 --detect_adapter_for_pe'
    ratio_upper        = 3.16227766
    ratio_lower        = 0.316227766
    entropy_threshold  = 0.0
}

includeConfig 'conf/base.config'

process {
    container = 'codonyat:latest'
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]
}

profiles {
    docker {
        docker.enabled       = true
        singularity.enabled  = false
    }
    singularity {
        singularity.enabled  = true
        docker.enabled       = false
    }
    test {
        params.input     = "${projectDir}/data/samplesheet.csv"
        params.reference = "${projectDir}/data/HXB2R.fasta"
        params.amplicons = "${projectDir}/data/amplicons.tsv"
    }
}
