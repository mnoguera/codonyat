params {
    input              = null
    reference          = null
    amplicons          = null
    protein            = 'RT'
    outdir             = './results'
    skip_dedup         = true
    skip_fastqc        = false
    bowtie2_args       = '--very-sensitive-local --no-unal'
    fastp_args         = '--qualified_quality_phred 20 --length_required 50 --detect_adapter_for_pe'
    ratio_upper        = 3.16227766
    ratio_lower        = 0.316227766
    entropy_threshold  = 0.0
    docker_image       = 'codonyat:latest'
    aws_region         = 'us-east-1'
    aws_batch_queue    = null
    aws_workdir        = null
    aws_outdir         = null
    aws_container      = null
}

includeConfig 'conf/base.config'

process {
    container = params.docker_image
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]
}

profiles {
    docker {
        docker.enabled       = true
        singularity.enabled  = false
    }
    awsbatch {
        docker.enabled       = false
        singularity.enabled  = false

        process.executor     = 'awsbatch'
        process.queue        = params.aws_batch_queue
        process.container    = params.aws_container ?: process.container

        aws.region           = params.aws_region

        // AWS Batch requires an S3 work directory.
        workDir              = params.aws_workdir

        // Override local output path for cloud runs when provided.
        params.outdir        = params.aws_outdir ?: params.outdir
    }
    singularity {
        singularity.enabled  = true
        docker.enabled       = false
    }
    test {
        params.input     = "${projectDir}/data/samplesheet.csv"
        params.reference = "${projectDir}/data/HXB2R.fasta"
        params.amplicons = "${projectDir}/data/amplicons.tsv"
        
        includeConfig 'conf/test.config'
    }
}
