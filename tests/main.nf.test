nextflow_pipeline {
    name   "Full pipeline"
    script "main.nf"

    // Uses the `docker` profile (enables container runtime) and the
    // `test` profile (supplies input/reference/amplicons from data/).
    profile "docker,test"

    test("runs end-to-end and produces expected outputs") {
        when {
            params {
                outdir = "${outputDir}"
            }
        }

        then {
            assert workflow.success
            def tsv = path("${outputDir}/codonyat/HVG286PL_S2_L001.sam.tsv")
            def xml = path("${outputDir}/codonyat/HVG286PL_S2_L001.sam.xml")

            assert tsv.exists()
            assert xml.exists()
            assert tsv.text.contains("FILE\tREFERENCE\tPROTEIN\tVARIANT\tPOSITION")
            assert tsv.text.contains("HVG286PL_S2_L001.sam")
            assert xml.text.contains("<SamContainer")
            assert xml.text.contains("<Position index=\"2550\">")
        }
    }
}
