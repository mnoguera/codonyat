process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = 8.GB
        time   = 4.h
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = 16.GB
        time   = 8.h
    }
}
